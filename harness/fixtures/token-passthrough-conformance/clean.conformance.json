{
  "schema": "assay.token_passthrough_conformance.v0",
  "topology": "consuming_path",
  "probed_inbound_auth_sources": [
    { "source": "http.authorization", "probed": true, "consumed": false },
    { "source": "http.cookie", "probed": true, "consumed": false },
    { "source": "http.x_api_key", "probed": true, "consumed": false },
    { "source": "initialize.params.authorization", "probed": true, "consumed": true },
    { "source": "initialize.params.initializationOptions.authorization", "probed": true, "consumed": true }
  ],
  "outbound_channels": [
    { "channel": "transport_header", "checked": true, "leak_count": 0, "pass": true },
    { "channel": "json_body", "checked": true, "leak_count": 0, "pass": true },
    { "channel": "environment", "checked": false, "not_applicable": true, "leak_count": 0 }
  ],
  "transparent_relay": {
    "in_scope": false,
    "reason": "relay path does not consume inbound auth; verbatim JSON-RPC forwarding is relay behaviour, not consumed-token passthrough"
  },
  "non_claims": [
    "tracks only consumed inbound authentication values",
    "does not scrub arbitrary credential-shaped user payload",
    "does not verify provider token grants",
    "does not manage token lifecycle, rotation, or vaulting"
  ]
}
