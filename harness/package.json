{
  "name": "assay-harness",
  "version": "0.10.1",
  "description": "Approval-aware resumable harness with Assay policy and evidence governance",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "assay-harness": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "run:harness": "tsx src/cli.ts run",
    "run:verify": "tsx src/cli.ts verify",
    "test": "npm run build && npm run check:hotspots && node --test test/*.mjs",
    "test:fuzz": "npm run build && node --test test/suite_evidence_pack_fuzz.test.mjs",
    "typecheck": "tsc --noEmit",
    "check:hotspots": "node scripts/check-hotspot-loc.mjs"
  },
  "dependencies": {
    "@openai/agents": "^0.13.5",
    "js-yaml": "^5.2.1",
    "openai": "^6.48.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
