{
  "name": "assay-harness",
  "version": "0.1.0",
  "description": "Approval-aware resumable harness with Assay policy and evidence governance",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "assay-harness": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "run:harness": "tsx src/cli.ts run",
    "run:verify": "tsx src/cli.ts verify",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openai/agents": "^0.1.0",
    "js-yaml": "^4.1.0",
    "openai": "^6.34.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
}
